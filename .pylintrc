[MASTER]
# Use multiple processes to speed up Pylint
jobs=1

[MESSAGES CONTROL]
# Disable specific messages
# C0111: missing-docstring (too broad: all public items would need docstrings)
# R0913: too-many-arguments (intentional: CLI tools have many config parameters)
# R0914: too-many-locals (intentional: pipeline functions need many tracking vars)
# R0917: too-many-positional-arguments (Python 3.12+ only check)
# R0912: too-many-branches (complex logic required in merge/search algorithms)
# R0915: too-many-statements (long functions with clear sequential structure)
# R0801: duplicate-code (acceptable for similar stdin/file I/O patterns)
#
# Re-enabled (addressed inline):
#   W0718: broad-exception-caught → inline disables with reason comments
#   W0621: redefined-outer-name  → no violations found in current code
#   R1732: consider-using-with   → inline disables (conditional stdin/file handles)
#   W1514: unspecified-encoding  → inline disables (system encoding intentional)
#   R1705: no-else-return        → inline disables (elif chains aid readability)
disable=C0111,R0913,R0914,R0917,R0912,R0915,R0801

[FORMAT]
# Maximum number of characters on a single line
max-line-length=100

[BASIC]
# Good variable names which should always be accepted
good-names=i,j,k,ex,Run,_,f,fh

[DESIGN]
# Maximum number of arguments for function / method
max-args=7
# Maximum number of locals for function / method body
max-locals=20
